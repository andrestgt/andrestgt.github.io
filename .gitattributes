# Enforce LF line endings for all text content.
# Overrides core.autocrlf so Windows checkout never re-introduces CRLF.
* text=auto eol=lf
*.md   text eol=lf
*.html text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.txt  text eol=lf

# Binary — never touch line endings
*.jpg   binary
*.jpeg  binary
*.png   binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
